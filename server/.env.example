# PostgreSQL
DATABASE_URL="postgresql://biz:biz_pass@localhost:5432/biz_finance?schema=public"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Server
PORT=4000
CORS_ORIGIN="http://localhost:5173"

# Базова валюта
BASE_CURRENCY="UAH"

# НБУ (опційний модуль): true = дозволити підтягувати курс з API НБУ
NBU_ENABLED="true"
NBU_API_URL="https://bank.gov.ua/NBUStatService/v1/statdirectory/exchange"

# Дані власника за замовчуванням (для seed)
OWNER_EMAIL="owner@biz.local"
OWNER_PASSWORD="owner12345"
